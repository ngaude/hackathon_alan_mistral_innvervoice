# Copier vers `.env` à la racine du dépôt (`cp .env.example .env`) puis renseigner les valeurs.
# Expo charge ce fichier via `app.config.js` (dotenv).

# --- Voice provider switch: "mistral" (default) or "elevenlabs" ---
VOICE_PROVIDER=elevenlabs

# --- Mistral (used when VOICE_PROVIDER=mistral) ---
MISTRAL_API_KEY=
# Chat completions model (optional; default mistral-large-latest)
# MISTRAL_CHAT_MODEL=mistral-small-2506

# Slug API voix agent neutre (liste : GET https://api.mistral.ai/v1/audio/voices — pas l'alias court `marie`).
MISTRAL_DEFAULT_AGENT_VOICE_ID=gb_jane_neutral

# --- ElevenLabs (used when VOICE_PROVIDER=elevenlabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_AGENT_VOICE_ID=0G7xjh2pNSLRvJSpklE4

# --- Optionnel (app + build Expo) ---
# MISTRAL_AGENT_VOICE_ID=
# MISTRAL_TTS_MODEL=
# MISTRAL_STT_MODEL=
# MISTRAL_INNERVOICE_SIMULATED_VOICE_ID=gb_jane_neutral
# EXPO_PUBLIC_DEBUG_MISTRAL=0

# Serveur : logs chiffrés de latence (STT, étapes ANCHOR_SUBMIT, durée applyEvent) — `npm run server:dev`
# INNERVOICE_PERF_LOG=1

# URL explicite du serveur session (sinon auto : http://<IP LAN du poste>:8787 au démarrage de Metro)
# EXPO_PUBLIC_INNERVOICE_API_URL=http://192.168.1.10:8787
# EXPO_PUBLIC_INNERVOICE_API_PORT=8787

# Si le serveur impose un secret (voir INNERVOICE_SERVER_SECRET côté `server/`)
# EXPO_PUBLIC_INNERVOICE_API_SECRET=

# Conversion M4A → WAV distante (Expo Go / Android), optionnel
# EXPO_PUBLIC_REF_AUDIO_CONVERT_URL=
# EXPO_PUBLIC_REF_AUDIO_CONVERT_SECRET=
